# Side Quest Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_ENV=production
APP_URL=https://yourdomain.com
APP_NAME=MyLifeIsBoringAndIWantToDoASideQuestButDontKnowWhatToDo

# Development Mode (false for production)
DEVELOPMENT_MODE=false

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=sidequest_user
DB_PASS=your_secure_password_here
DB_NAME=sidequest_app

# Admin Secret URL (change this!)
ADMIN_URL_SECRET=your_super_secret_admin_url_here

# Session Timeout (in seconds)
SESSION_TIMEOUT=86400  # 24 hours

# Upload Configuration
MAX_UPLOAD_SIZE=5242880  # 5MB in bytes

# Email Configuration (optional)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@sidequest.app
